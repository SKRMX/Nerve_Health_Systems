{
    "name": "nerve-desktop",
    "version": "1.0.0",
    "description": "NERVE Health Systems Desktop Client",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder -w"
    },
    "author": "NERVE Health Systems",
    "license": "ISC",
    "build": {
        "appId": "com.nervehealthsystems.desktop",
        "productName": "NERVE Health Systems",
        "win": {
            "target": "nsis"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true
        }
    },
    "devDependencies": {
        "electron": "^40.6.1",
        "electron-builder": "^26.8.1",
        "electron-packager": "^17.1.2",
        "png-to-ico": "^3.0.1",
        "sharp": "^0.34.5"
    }
}
