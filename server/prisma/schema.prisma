// ================================================
// NERVE Health Systems — Prisma Schema
// ================================================

// ⚠️ DISCLAIMER: NERVE Health Systems es una herramienta de gestión
// administrativa para clínicas y consultorios. NO es un dispositivo
// médico ni sustituye el criterio profesional del médico. Los datos
// clínicos (notas médicas, diagnósticos) se almacenan en texto plano
// sin cifrado a nivel de campo. La seguridad se gestiona a nivel de
// transporte (TLS/HTTPS) y acceso (JWT + RBAC + Multi-tenancy).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Organizations (Hospitals / Clinics) ----
model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  plan        String   @default("trial") // trial, starter, clinica_pro, enterprise
  maxDoctors  Int      @default(3)
  location    String?
  city        String?
  phone       String?
  email       String?
  active      Boolean  @default(true)
  whatsappConnected Boolean @default(false) @map("whatsapp_connected")
  whatsappNumber    String?  @map("whatsapp_number")
  mpSubscriptionId String? @map("mp_subscription_id")
  subscriptionExpires DateTime? @map("subscription_expires")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  patients    Patient[]
  departments Department[]
  subscriptions Subscription[]
  payments      Payment[]

  @@map("organizations")
}

// ---- Users (all roles) ----
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         String   // superadmin, org_owner, dept_head, doctor, asistente, patient
  specialty    String?
  license      String?
  phone        String?
  avatarUrl    String?  @map("avatar_url")
  active       Boolean  @default(true)

  orgId        String?  @map("org_id")
  org          Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  departmentId String?  @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  // Relations
  patients      Patient[]      @relation("DoctorPatients")
  appointments  Appointment[]  @relation("DoctorAppointments")
  prescriptions Prescription[] @relation("DoctorPrescriptions")
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@map("users")
}

// ---- Patients ----
model Patient {
  id           String   @id @default(uuid())
  name         String
  email        String?
  phone        String?
  dob          DateTime? @map("date_of_birth")
  gender       String?
  bloodType    String?  @map("blood_type")
  allergies    String?
  diagnosis    String?
  medicalNotes String?  @map("medical_notes")
  status       String   @default("Activo")

  doctorId     String   @map("doctor_id")
  doctor       User     @relation("DoctorPatients", fields: [doctorId], references: [id])

  orgId        String   @map("org_id")
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  appointments  Appointment[]
  prescriptions Prescription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId])
  @@index([orgId])
  @@map("patients")
}

// ---- Appointments ----
model Appointment {
  id        String   @id @default(uuid())
  date      DateTime
  time      String
  type      String   // consulta, seguimiento, primera_vez, urgencia
  status    String   @default("programada") // programada, completada, cancelada, no_asistio
  reason    String?
  notes     String?

  reminderSentAt   DateTime? @map("reminder_sent_at")
  reminder2hSentAt DateTime? @map("reminder_2h_sent_at")

  patientId String   @map("patient_id")
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  doctorId  String   @map("doctor_id")
  doctor    User     @relation("DoctorAppointments", fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([doctorId])
  @@map("appointments")
}

// ---- Prescriptions ----
model Prescription {
  id          String   @id @default(uuid())
  medication  String
  dosage      String
  frequency   String
  duration    String
  notes       String?
  batchId     String?  @map("batch_id")
  active      Boolean  @default(true)

  patientId   String   @map("patient_id")
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  doctorId    String   @map("doctor_id")
  doctor      User     @relation("DoctorPrescriptions", fields: [doctorId], references: [id])

  createdAt DateTime @default(now())

  @@map("prescriptions")
}

// ---- Departments ----
model Department {
  id     String @id @default(uuid())
  name   String

  orgId  String @map("org_id")
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  users  User[]

  @@map("departments")
}

// ---- Subscriptions (Mercado Pago) ----
model Subscription {
  id              String   @id @default(uuid())
  plan            String   // starter, clinica_pro
  status          String   @default("pending") // pending, active, paused, cancelled, expired
  amount          Int      // amount in MXN cents (e.g. 99900 = $999)
  currency        String   @default("MXN")
  billingCycle    String   @default("monthly") @map("billing_cycle") // monthly, annual
  mpPreferenceId  String?  @map("mp_preference_id")
  mpPaymentId     String?  @map("mp_payment_id")
  trialEndsAt     DateTime? @map("trial_ends_at")
  currentPeriodStart DateTime? @map("current_period_start")
  currentPeriodEnd   DateTime? @map("current_period_end")

  orgId   String @map("org_id")
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([status])
  @@map("subscriptions")
}

// ---- Payments (individual payment records) ----
model Payment {
  id              String   @id @default(uuid())
  amount          Int      // amount in MXN cents
  currency        String   @default("MXN")
  status          String   // approved, pending, rejected, refunded
  mpPaymentId     String?  @unique @map("mp_payment_id")
  mpStatus        String?  @map("mp_status")
  mpStatusDetail  String?  @map("mp_status_detail")
  description     String?

  subscriptionId  String?  @map("subscription_id")
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])

  orgId           String   @map("org_id")
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([mpPaymentId])
  @@map("payments")
}

// ---- Audit Log ----
model AuditLog {
  id        String   @id @default(uuid())
  action    String   // CREATE, READ, UPDATE, DELETE, LOGIN, LOGOUT
  entity    String   // patient, appointment, prescription, user, organization
  entityId  String?  @map("entity_id")
  details   String?
  ip        String?

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
