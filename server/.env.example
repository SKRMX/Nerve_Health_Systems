# ================================================
# NERVE Health Systems — Environment Variables
# Copy this file to .env and fill in your values
# ================================================

# Database
DATABASE_URL="postgresql://nerve_user:YOUR_DB_PASSWORD@localhost:5432/nerve_prod?schema=public&connection_limit=50"

# JWT (generate secure 64-char random strings, e.g.: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING"
JWT_REFRESH_SECRET="CHANGE_ME_TO_ANOTHER_RANDOM_64_CHAR_STRING"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV="development"
CLIENT_URL="http://localhost:3000"

# Mercado Pago
MP_ACCESS_TOKEN="YOUR_MERCADO_PAGO_ACCESS_TOKEN"
MP_PUBLIC_KEY="YOUR_MERCADO_PAGO_PUBLIC_KEY"

# Super Admin (initial setup — change password immediately after first login)
SUPER_ADMIN_EMAIL="admin@nervehealthsystems.com"
SUPER_ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
SUPER_ADMIN_NAME="Admin"

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS="http://localhost:3000,https://nervehealthsystems.com,https://www.nervehealthsystems.com"

# WhatsApp Chromium path (auto-detect if empty)
CHROMIUM_PATH=""
