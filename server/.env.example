# Server Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL="postgresql://nerve_user:YOUR_DB_PASSWORD@localhost:5432/nerve_prod?schema=public"

# JWT
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING"
JWT_REFRESH_SECRET="CHANGE_ME_TO_ANOTHER_RANDOM_64_CHAR_STRING"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV="development"
CLIENT_URL="http://localhost:3000"

# Encryption (for medical data)
ENCRYPTION_KEY="CHANGE_ME_TO_A_32_BYTE_HEX_STRING"

# Mercado Pago (when ready)
# MP_ACCESS_TOKEN=""
# MP_PUBLIC_KEY=""

# Super Admin (initial setup)
SUPER_ADMIN_EMAIL="mauricio@nervehealthsystems.com"
SUPER_ADMIN_PASSWORD="palmera22022800"
SUPER_ADMIN_NAME="MauricioCV"
